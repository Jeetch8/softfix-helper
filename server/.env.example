# Server Configuration
PORT=3000
NODE_ENV=production

# MongoDB Configuration (External Instance)
# Provide your deployed MongoDB connection string
# Examples:
# mongodb://username:password@host:port/database
# mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb://your_mongodb_uri_here

# Google Cloud Vertex AI Configuration (Enterprise API)
# To find your Project ID, visit: https://console.cloud.google.com/
GCP_PROJECT=your_gcp_project_id_here
GCP_LOCATION=us-global

# Gemini AI API Key (Developer API - Legacy)
# Get your free API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Cron Job Configuration
# Current schedule: every 2 minutes (*/2 * * * *)
# Modify in server/services/cronService.js if needed
CRON_SCHEDULE=*/2 * * * *

# Optional: Logging
LOG_LEVEL=info

